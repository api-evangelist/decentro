{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://schema.decentro.tech/",
    "schema": "https://schema.org/",
    "decentro": "https://schema.decentro.tech/",
    "VirtualAccount": "decentro:VirtualAccount",
    "Payout": "decentro:Payout",
    "Mandate": "decentro:Mandate",
    "JournalEntry": "decentro:JournalEntry",
    "account_number": {"@id": "schema:accountId", "@type": "schema:Text"},
    "ifsc": {"@id": "decentro:ifsc", "@type": "schema:Text"},
    "balance": {"@id": "schema:amount", "@type": "schema:Number"},
    "amount": {"@id": "schema:amount", "@type": "schema:Number"},
    "currency": {"@id": "schema:priceCurrency", "@type": "schema:Text"},
    "status": {"@id": "decentro:status", "@type": "schema:Text"},
    "transfer_type": {"@id": "decentro:transferType", "@type": "schema:Text"},
    "purpose_message": {"@id": "schema:description", "@type": "schema:Text"}
  }
}
